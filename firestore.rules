rules_version = '2';

/**
 * CulturePass AU — Firestore Security Rules
 *
 * Architecture note:
 *   All writes go through Cloud Functions (Admin SDK) which BYPASS these rules.
 *   These rules protect direct client-SDK reads only.
 *   Writes from the client are blocked on every collection.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() &&
        request.auth.token.get('role', 'user') in ['admin', 'moderator'];
    }

    // ── Users ───────────────────────────────────────────────────────────────
    // Users can read their own document; admins can read all.
    // Writes always go through the API (Admin SDK).
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false;
    }

    // ── Events ──────────────────────────────────────────────────────────────
    // Anyone can read published events (status == 'published').
    // Draft/deleted events are readable only by the organizer or admin.
    match /events/{eventId} {
      allow read: if resource.data.status == 'published'
                  || isAdmin()
                  || (isSignedIn() && resource.data.organizerId == request.auth.uid);
      allow write: if false;
    }

    // ── Tickets ─────────────────────────────────────────────────────────────
    // Ticket owner can read their own tickets. Admins can read all.
    // All writes via Admin SDK (no direct client writes).
    match /tickets/{ticketId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow write: if false;
    }

    // ── Profiles (community / business / venue / artist) ────────────────────
    // Anyone (including unauthenticated) can browse profiles.
    match /profiles/{profileId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Notifications ────────────────────────────────────────────────────────
    // Users can read their own notifications.
    match /notifications/{notifId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow write: if false;
    }

    // ── Wallets ──────────────────────────────────────────────────────────────
    match /wallets/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false;
    }

    // ── Perks ────────────────────────────────────────────────────────────────
    // Anyone can browse available perks; only Cloud Functions can write.
    match /perks/{perkId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Redemptions ──────────────────────────────────────────────────────────
    match /redemptions/{redemptionId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow write: if false;
    }

    // ── Reports ──────────────────────────────────────────────────────────────
    // Only admins/moderators can read reports.
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── Event Feedback ───────────────────────────────────────────────────────
    match /eventFeedback/{feedbackId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Media ────────────────────────────────────────────────────────────────
    match /media/{mediaId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Stripe Events (idempotency) ──────────────────────────────────────────
    match /stripeEvents/{eventId} {
      allow read, write: if false;
    }

    // ── Catch-all ─────────────────────────────────────────────────────────────
    // Deny everything else — Cloud Functions handle all other operations.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}