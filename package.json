{
  "name": "culturepassau",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "node functions/lib/functions/src/server.js",
    "build": "npm ci --prefix functions && npm run build --prefix functions",
    "expo:start": "npx expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "postinstall": "patch-package",
    "expo:dev": "EXPO_PACKAGER_PROXY_URL=https://$REPLIT_DEV_DOMAIN REACT_NATIVE_PACKAGER_HOSTNAME=$REPLIT_DEV_DOMAIN EXPO_PUBLIC_DOMAIN=$REPLIT_DEV_DOMAIN:5000 npx expo start --localhost",
    "expo:start:static:build": "npx expo start --no-dev --minify --localhost",
    "expo:static:build": "node scripts/build.js",
    "functions:build": "cd functions && npm run build",
    "server:dev": "tsx scripts/server-dev.ts",
    "lint": "npx expo lint",
    "lint:fix": "npx expo lint --fix",
    "typecheck": "tsc --noEmit",
    "test:native-intent": "tsx scripts/test-native-intent.ts",
    "test:navigation": "tsx scripts/tests/unit-navigation.ts",
    "test:unit": "tsx scripts/tests/unit-services-middleware.ts",
    "test:integration": "tsx scripts/tests/integration-api-routes.ts",
    "test:e2e:smoke": "tsx scripts/tests/e2e-critical-smoke.ts",
    "qa:all": "npm run test:package-json && npm run test:unit && npm run test:navigation && npm run test:integration && npm run test:e2e:smoke",
    "test:package-json": "tsx scripts/tests/validate-package-json.ts",
    "deploy-all": "cd functions && npm run build && cd .. && firebase deploy --only functions && EXPO_NO_TELEMETRY=1 npx expo export --platform web && firebase deploy --only hosting"
  },
  "dependencies": {
    "@expo-google-fonts/poppins": "^0.4.1",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.1",
    "@stardazed/streams-text-encoding": "^1.0.2",
    "@tanstack/react-query": "^5.90.21",
    "@types/qrcode": "^1.5.6",
    "@ungap/structured-clone": "^1.3.0",
    "expo": "~55.0.4",
    "expo-apple-authentication": "~55.0.8",
    "expo-blur": "~55.0.8",
    "expo-camera": "~55.0.9",
    "expo-clipboard": "~55.0.8",
    "expo-constants": "~55.0.7",
    "expo-crypto": "~55.0.8",
    "expo-font": "~55.0.4",
    "expo-glass-effect": "~55.0.7",
    "expo-haptics": "~55.0.8",
    "expo-image": "~55.0.5",
    "expo-image-manipulator": "~55.0.9",
    "expo-image-picker": "~55.0.9",
    "expo-linear-gradient": "~55.0.8",
    "expo-linking": "~55.0.7",
    "expo-location": "~55.1.2",
    "expo-router": "~55.0.2",
    "expo-secure-store": "~55.0.8",
    "expo-splash-screen": "~55.0.9",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.4",
    "expo-system-ui": "~55.0.9",
    "expo-web-browser": "~55.0.9",
    "firebase": "^11.0.0",
    "qrcode": "^1.5.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-keyboard-controller": "1.20.7",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-maps": "1.26.20",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-snap-carousel": "^1.3.1",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.2",
    "tsx": "^4.20.6",
    "ws": "^8.18.0",
    "zod": "^3.24.2",
    "zod-validation-error": "^3.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/ngrok": "^4.1.0",
    "@types/react": "~19.2.10",
    "babel-plugin-react-compiler": "^19.0.0-beta-e993439-20250117",
    "eslint": "^9.31.0",
    "eslint-config-expo": "~55.0.0",
    "patch-package": "^8.0.0",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "minimatch": "10.2.1",
    "@isaacs/brace-expansion": "5.0.1",
    "tar": "7.5.8"
  }
